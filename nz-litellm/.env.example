# nz-litellm .env.example
# Copy to .env and fill with actual values

# Qdrant Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# PostgreSQL Database
# Format: postgresql://user:password@host:port/dbname
POSTGRES_URL=postgresql://YOUR_USER:YOUR_PASSWORD@postgres:5432/genesis

# LiteLLM API Gateway
LITELLM_API_URL=http://litellm:4000

# LLM Model Selection
DEFAULT_MODEL=groq/llama3-8b-8192

# Collection Name for Vector Storage
# COLLECTION_NAME=genesis-knowledge
