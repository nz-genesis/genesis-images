# Timezone
TZ=Europe/Kyiv

# LiteLLM
LITELLM_MASTER_KEY=sk-litellm-master-key-...
LITELLM_SALT_KEY=salt-...

# Database
DATABASE_URL=postgresql://litellm_user:password@192.168.31.201:5432/litellm_db

# Redis
REDIS_HOST=192.168.31.201
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_URL=redis://:password@192.168.31.201:6379/0

# Cache
LITELLM_CACHE_TTL=3600

# API Keys (examples - use real keys in .env.prod)
OPENROUTER_API_KEY=sk-or-your-real-key-here
GROQ_API_KEY=gsk_...

# Optional services
MEM0_URL=http://192.168.31.201:8090
LIGHTRAG_URL=http://192.168.31.201:7789
JINA_CLIP_URL=http://192.168.31.207:8000

# LiteLLM UI
LITELLM_TELEMETRY=false
PROXY_CONFIG_PATH=/app/proxy_config.yaml
