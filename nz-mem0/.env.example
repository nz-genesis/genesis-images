# NZ-MEM0 .env.example — DO NOT store secrets in repo; use Portainer Secrets in production.

HOST=0.0.0.0
PORT=8090

# SQL backend (preferred). Example:
# MEM0_DATABASE_URL=postgresql://user:pass@192.168.31.201:5432/mem0
# If not set, sqlite fallback will be used:
MEM0_DATABASE_URL=

# sqlite fallback path (inside container named volume /data)
DB_PATH=/data/mem0.db

# Qdrant vector DB (optional)
MEM0_QDRANT_URL=http://192.168.31.201:6333
MEM0_QDRANT_API_KEY=

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MEM0_ENABLE_EMBEDDINGS=true

# Audit / logging
AUDIT_ENABLED=false
AUDIT_LOG_PATH=/data/audit.log
LOG_LEVEL=info

# Security
API_KEY=

# Debug
MEM0_DEBUG_MODE=false
